@page
@model SWD.Pages.Courses.EnrollModel
@{
    ViewData["Title"] = "Xác nhận đăng ký";
}

<div class="container py-4" style="max-width:600px">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Courses/Index">Danh sách lớp</a></li>
            <li class="breadcrumb-item active">Xác nhận đăng ký</li>
        </ol>
    </nav>

    <h3 class="mb-4">📋 Xác nhận ghi danh</h3>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-x-circle-fill me-2 fs-5"></i>
            <div>
                <strong>Không thể đăng ký:</strong> @Model.ErrorMessage
                <div class="mt-2">
                    <a asp-page="/Courses/Index" asp-route-SelectedStudentId="@Model.StudentId"
                       class="btn btn-sm btn-outline-danger">← Quay lại danh sách lớp</a>
                </div>
            </div>
        </div>
    }

    @if (Model.SelectedClass != null && Model.CurrentStudent != null && Model.ErrorMessage == null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@Model.SelectedClass.Course.CourseName</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <th class="text-muted" style="width:40%">Lớp</th>
                        <td><strong>@Model.SelectedClass.ClassName</strong></td>
                    </tr>
                    <tr>
                        <th class="text-muted">Lịch học</th>
                        <td>@Model.SelectedClass.Schedule.DayName, @Model.SelectedClass.Schedule.StartTime.ToString(@"hh\:mm")–@Model.SelectedClass.Schedule.EndTime.ToString(@"hh\:mm")</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Học phí</th>
                        <td class="text-success fw-bold fs-5">@Model.SelectedClass.Course.Fee.ToString("N0") ₫</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Học viên</th>
                        <td>@Model.CurrentStudent.StudentName</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="alert alert-info small">
            <i class="bi bi-info-circle"></i>
            Nhấn <strong>Tiến hành thanh toán</strong>, hệ thống sẽ kiểm tra điều kiện tiên quyết,
            lịch học và sức chứa lớp trước khi chuyển sang bước thanh toán (UC18).
        </div>

        <form method="post">
            <input type="hidden" name="ClassId"   value="@Model.ClassId"/>
            <input type="hidden" name="StudentId" value="@Model.StudentId"/>
            <div class="d-flex gap-2">
                <a asp-page="/Courses/Index" asp-route-SelectedStudentId="@Model.StudentId"
                   class="btn btn-outline-secondary flex-fill">← Hủy</a>
                <button type="submit" class="btn btn-primary flex-fill">
                    💳 Tiến hành thanh toán
                </button>
            </div>
        </form>
    }
</div>
