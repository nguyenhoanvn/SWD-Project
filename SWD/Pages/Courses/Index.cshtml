@page
@model SWD.Pages.Courses.IndexModel
@using SWD.Domain.Models
@{
    ViewData["Title"] = "Danh sách lớp học";
}

<div class="container py-4">
    <h2 class="mb-1">Danh sách lớp học</h2>
    <p class="text-muted mb-4">Cambridge English Center — Chọn lớp và tiến hành ghi danh</p>

    <div class="card border-warning mb-4">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-auto"><label class="col-form-label fw-semibold">Đang đăng nhập là:</label></div>
                <div class="col-auto">
                    <select name="SelectedStudentId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Chọn học viên --</option>
                        @foreach (var s in Model.Students)
                        {
                            <option value="@s.StudentId" selected="@(Model.SelectedStudentId == s.StudentId)">
                                @s.StudentName (@s.Email)
                            </option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    @if (Model.SelectedStudentId == null)
    {
        <div class="alert alert-info">Vui lòng chọn học viên để bắt đầu.</div>
    }

    <div class="row g-3">
        @foreach (var cls in Model.AvailableClasses)
        {
            int enrolled  = cls.Registrations.Count(r => r.Status != RegistrationStatus.Cancelled);
            int remaining = cls.Capacity - enrolled;
            bool full     = remaining <= 0;

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-header bg-primary text-white d-flex justify-content-between">
                        <strong>@cls.Course.CourseName</strong>
                        @if (full)
                        {
                            <span class="badge bg-danger">Hết chỗ</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark">Còn @remaining chỗ</span>
                        }
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><i class="bi bi-door-open"></i> <strong>@cls.ClassName</strong></p>
                        <p class="mb-1 text-muted small">@cls.Course.Description</p>
                        <hr class="my-2"/>
                        <p class="mb-1">@cls.Schedule.DayName — @cls.Schedule.StartTime.ToString(@"hh\:mm") – @cls.Schedule.EndTime.ToString(@"hh\:mm")</p>
                        <p class="mb-1">Sĩ số: @enrolled / @cls.Capacity</p>
                        @if (cls.Course.ScoreCondition > 0)
                        {
                            <p class="mb-1 text-warning">Yêu cầu điểm ≥ @cls.Course.ScoreCondition</p>
                        }
                        <p class="mb-0 fw-bold text-success fs-5">@cls.Course.Fee.ToString("N0") ₫</p>
                    </div>
                    <div class="card-footer">
                        @if (Model.SelectedStudentId != null && !full)
                        {
                            <a asp-page="/Courses/Enroll"
                               asp-route-classId="@cls.ClassId"
                               asp-route-studentId="@Model.SelectedStudentId"
                               class="btn btn-primary w-100">
                                Đăng ký lớp này
                            </a>
                        }
                        else if (full)
                        {
                            <button class="btn btn-secondary w-100" disabled>Lớp đã đầy</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-primary w-100" disabled>Chọn học viên để đăng ký</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
