@page
@model SWD.Pages.Payment.ProcessModel
@{
    ViewData["Title"] = "Thanh toán học phí";
}

<div class="container py-4" style="max-width:580px">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Courses/Index">Danh sách lớp</a></li>
            <li class="breadcrumb-item active">Thanh toán</li>
        </ol>
    </nav>

    <h3 class="mb-4">💳 Thanh toán học phí</h3>

    @if (Model.Registration != null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white">
                <small class="opacity-75">Mã đơn hàng</small>
                <div class="fw-semibold font-monospace">@Model.RegistrationId</div>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0 small">
                    <tr>
                        <th class="text-muted">Học viên</th>
                        <td>@Model.Registration.Student?.StudentName</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Khóa học</th>
                        <td>@Model.Registration.Class?.Course?.CourseName</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Lớp</th>
                        <td>@Model.Registration.Class?.ClassName</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Ngày đăng ký</th>
                        <td>@Model.Registration.RegistrationDate.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                </table>
                <hr/>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fs-5 text-muted">Tổng thanh toán:</span>
                    <span class="fs-3 fw-bold text-success">
                        @Model.Registration.Class?.Course?.Fee.ToString("N0") ₫
                    </span>
                </div>
            </div>
        </div>


        <form method="post">
            <input type="hidden" name="RegistrationId" value="@Model.RegistrationId"/>
            <input type="hidden" name="StudentId"      value="@Model.StudentId"/>

            <div class="card shadow-sm mb-4">
                <div class="card-header fw-semibold">Chọn phương thức thanh toán</div>
                <div class="card-body">
                    @foreach (var method in new[] { ("MoMo", "💜", "ví MoMo"), ("VNPay", "🔴", "VNPay QR"), ("ZaloPay", "🔵", "ZaloPay"), ("TestFail", "❌", "Giả lập thanh toán thất bại") })
                    {
                        <div class="form-check border rounded p-3 mb-2 @(Model.SelectedMethod == method.Item1 ? "border-primary bg-primary bg-opacity-10" : "")">
                            <input class="form-check-input" type="radio"
                                   name="SelectedMethod" id="@method.Item1"
                                   value="@method.Item1"
                                   @(Model.SelectedMethod == method.Item1 ? "checked" : "")/>
                            <label class="form-check-label d-flex align-items-center gap-2" for="@method.Item1">
                                <span class="fs-4">@method.Item2</span>
                                <strong>@method.Item3</strong>
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="alert alert-secondary small">
                <i class="bi bi-shield-lock"></i>
                <strong>Demo mode:</strong> Giao dịch sẽ được xử lý bởi <em>PaymentGatewayProxy</em> (giả lập).
                Mọi phương thức đều thành công trong môi trường này.
            </div>

            <div class="d-flex gap-2">
                <button type="submit" asp-page-handler="Cancel"
                        class="btn btn-outline-secondary flex-fill">
                    Hủy thanh toán
                </button>
                <button type="submit" class="btn btn-success flex-fill fw-bold">
                    Xác nhận thanh toán
                </button>
            </div>
        </form>
    }
    else
    {
        <div class="alert alert-danger">Không tìm thấy đơn đăng ký.</div>
    }
</div>
