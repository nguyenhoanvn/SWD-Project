@page
@model SWD.Pages.Payment.ResultModel
@{
    ViewData["Title"] = Model.Success ? "Đăng ký thành công" : "Đăng ký thất bại";
}

<div class="container py-5" style="max-width:560px; text-align:center">

    @if (Model.Success)
    {
        <div class="mb-4" style="font-size:4rem">✅</div>
        <h3 class="text-success mb-2">Ghi danh thành công!</h3>
        <p class="text-muted">@Model.Message</p>

        <div class="card shadow-sm my-4 text-start">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small mb-3">Chi tiết giao dịch</h6>
                <div class="row g-2 small">
                    <div class="col-5 text-muted">Mã đơn đăng ký</div>
                    <div class="col-7 font-monospace">@Model.RegistrationId</div>
                    <div class="col-5 text-muted">Mã giao dịch</div>
                    <div class="col-7 font-monospace text-success">@Model.TxnRef</div>
                    <div class="col-5 text-muted">Thời gian</div>
                    <div class="col-7">@DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")</div>
                    <div class="col-5 text-muted">Trạng thái</div>
                    <div class="col-7"><span class="badge bg-success">ĐÃ THANH TOÁN</span></div>
                </div>
            </div>
        </div>

        <p class="small text-muted">
            📧 Email xác nhận đã được gửi đến hộp thư của bạn (qua <em>NotificationProxy</em>).
        </p>
    }
    else
    {
        <div class="mb-4" style="font-size:4rem">❌</div>
        <h3 class="text-danger mb-2">Đăng ký không thành công</h3>
        <p class="text-muted">@Model.Message</p>

        <div class="card shadow-sm my-4 text-start border-danger">
            <div class="card-body small">
                <div class="row g-2">
                    <div class="col-5 text-muted">Mã tham chiếu</div>
                    <div class="col-7 font-monospace text-danger">@Model.TxnRef</div>
                    <div class="col-5 text-muted">Trạng thái</div>
                    <div class="col-7"><span class="badge bg-danger">THẤT BẠI</span></div>
                </div>
            </div>
        </div>
    }

    <div class="d-flex gap-2 justify-content-center mt-4">
        <a asp-page="/Courses/Index" class="btn btn-outline-primary">← Về danh sách lớp</a>
        @if (!Model.Success)
        {
            <a asp-page="/Courses/Index" class="btn btn-primary">Thử lại</a>
        }
    </div>
</div>
