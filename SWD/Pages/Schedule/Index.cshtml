@page
@model SWD.Pages.Schedule.IndexModel
@using SWD.Models
@{
    ViewData["Title"] = "Thời khóa biểu";

    // Helper: tên thứ
    string DayName(int d) => d switch
    {
        2 => "Thứ 2", 3 => "Thứ 3", 4 => "Thứ 4",
        5 => "Thứ 5", 6 => "Thứ 6", 7 => "Thứ 7",
        _ => "Chủ nhật"
    };

    // Các ngày thực sự có lớp
    var activeDays = Model.AllClasses
        .Select(c => c.Schedule.DayOfWeek)
        .Distinct()
        .OrderBy(d => d)
        .ToList();
}

<div class="container py-4">
    <h2 class="mb-1">🗓 Thời khóa biểu</h2>
    <p class="text-muted mb-4">Cambridge English Center — Tổng hợp lịch tất cả các lớp</p>

    <div class="card border-primary mb-4">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-auto">
                    <label class="col-form-label fw-semibold">Xem lịch của học viên:</label>
                </div>
                <div class="col-auto">
                    <select name="SelectedStudentId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Chỉ xem tổng quan --</option>
                        @foreach (var s in Model.Students)
                        {
                            <option value="@s.StudentId"
                                    selected="@(Model.SelectedStudentId == s.StudentId)">
                                @s.StudentName
                            </option>
                        }
                    </select>
                </div>
                @if (Model.SelectedStudentId != null)
                {
                    <div class="col-auto">
                        <a asp-page="/Schedule/Index" class="btn btn-outline-secondary btn-sm">✕ Bỏ chọn</a>
                    </div>
                }
            </form>
        </div>
    </div>

    @if (Model.SelectedStudentId != null)
    {
        <div class="d-flex gap-3 mb-3 align-items-center flex-wrap">
            <div class="d-flex align-items-center gap-2">
                <div style="width:20px;height:20px;background:#0d6efd;border-radius:4px"></div>
                <span class="small">Lớp <strong>@Model.SelectedStudent?.StudentName</strong> đang học</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div style="width:20px;height:20px;background:#f8f9fa;border:1px solid #dee2e6;border-radius:4px"></div>
                <span class="small">Lớp khác</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div style="width:20px;height:20px;background:#dc3545;border-radius:4px"></div>
                <span class="small">Lớp có thể bị trùng lịch</span>
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-bordered text-center align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width:100px">Giờ</th>
                    @foreach (var day in activeDays)
                    {
                        <th>@DayName(day)</th>
                    }
                </tr>
            </thead>
            <tbody>
                @{
                    var timeSlots = Model.AllClasses
                        .Select(c => (c.Schedule.StartTime, c.Schedule.EndTime))
                        .Distinct()
                        .OrderBy(t => t.StartTime)
                        .ToList();
                }

                @foreach (var slot in timeSlots)
                {
                    <tr>
                        <td class="fw-semibold text-muted small">
                            @slot.StartTime.ToString(@"hh\:mm")<br/>
                            <span class="text-muted">–</span><br/>
                            @slot.EndTime.ToString(@"hh\:mm")
                        </td>

                        @foreach (var day in activeDays)
                        {
                            var classesInCell = Model.AllClasses
                                .Where(c => c.Schedule.DayOfWeek == day &&
                                            c.Schedule.StartTime == slot.StartTime &&
                                            c.Schedule.EndTime   == slot.EndTime)
                                .ToList();

                            <td class="p-1">
                                @foreach (var cls in classesInCell)
                                {
                                    bool isEnrolled = Model.EnrolledClassIds.Contains(cls.ClassId);

                                    bool isConflict = Model.SelectedStudentId != null &&
                                                      !isEnrolled &&
                                                      Model.AllClasses
                                                           .Any(ec => Model.EnrolledClassIds.Contains(ec.ClassId) &&
                                                                      ec.Schedule.DayOfWeek == cls.Schedule.DayOfWeek &&
                                                                      ec.Schedule.StartTime  < cls.Schedule.EndTime &&
                                                                      cls.Schedule.StartTime < ec.Schedule.EndTime);

                                    string cardClass = isEnrolled  ? "bg-primary text-white" :
                                                       isConflict  ? "bg-danger text-white"  :
                                                                     "bg-light";

                                    int enrolled  = cls.Registrations.Count(r => r.Status != RegistrationStatus.Cancelled);
                                    int remaining = cls.Capacity - enrolled;

                                    <div class="rounded p-2 mb-1 @cardClass" style="font-size:0.82rem">
                                        <div class="fw-bold">@cls.Course.CourseName</div>
                                        <div class="opacity-75">@cls.ClassName</div>
                                        <div class="mt-1">
                                            @if (isEnrolled)
                                            {
                                                <span class="badge bg-white text-primary">✓ Đang học</span>
                                            }
                                            else if (isConflict)
                                            {
                                                <span class="badge bg-white text-danger">⚠ Trùng lịch</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Còn @remaining chỗ</span>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (!classesInCell.Any())
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.SelectedStudentId != null && Model.EnrolledClassIds.Any())
    {
        <div class="card border-primary mt-4">
            <div class="card-header bg-primary text-white">
                Lớp <strong>@Model.SelectedStudent?.StudentName</strong> đang học
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Khóa học</th>
                            <th>Lớp</th>
                            <th>Lịch</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cls in Model.AllClasses.Where(c => Model.EnrolledClassIds.Contains(c.ClassId)))
                        {
                            <tr>
                                <td>@cls.Course.CourseName</td>
                                <td>@cls.ClassName</td>
                                <td>@cls.Schedule.DayName, @cls.Schedule.StartTime.ToString(@"hh\:mm")–@cls.Schedule.EndTime.ToString(@"hh\:mm")</td>
                                <td><span class="badge bg-primary">Đang học</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (Model.SelectedStudentId != null && !Model.EnrolledClassIds.Any())
    {
        <div class="alert alert-info mt-4">
            <strong>@Model.SelectedStudent?.StudentName</strong> chưa đăng ký lớp nào.
        </div>
    }

    <div class="text-center mt-4">
        <a asp-page="/Courses/Index" class="btn btn-primary">→ Đăng ký lớp</a>
    </div>
</div>
