@page
@model SWD.Pages.Students.IndexModel
@using SWD.Models
@{
    ViewData["Title"] = "Thông tin học viên";
}

<div class="container py-4">
    <h2 class="mb-1">Thông tin học viên</h2>
    <div class="card border-warning mb-4">
        <div class="card-header bg-warning text-dark fw-semibold">
           Demo Tools — Giả lập tình huống test
        </div>
        <div class="card-body">
            <p class="small text-muted mb-3">
                Dùng để tạo tình huống <strong>A3 — Lớp đầy</strong> trong UC02
            </p>
            <div class="d-flex gap-2 flex-wrap">

                <form method="post">
                    <button asp-page-handler="FillClass" name="classId" value="CL03"
                            class="btn btn-warning btn-sm">
                        Fill lớp Intermediate cho đầy
                    </button>
                </form>

                <form method="post">
                    <button asp-page-handler="FillClass" name="classId" value="CL04"
                            class="btn btn-warning btn-sm">
                        Fill lớp Advanced cho đầy
                    </button>
                </form>

                <form method="post">
                    <button asp-page-handler="FillClass" name="classId" value="CL01"
                            class="btn btn-warning btn-sm">
                        Fill lớp Foundation A cho đầy
                    </button>
                </form>

            </div>
            <div class="mt-2 small text-muted">
                ⚠Sau khi fill → sang trang <a asp-page="/Courses/Index">Đăng ký lớp</a>
                và thử đăng ký lớp đó → hệ thống báo <strong>"Lớp đã đầy"</strong>
            </div>
        </div>
    </div>

    @foreach (var student in Model.Students)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0">@student.StudentName</h5>
                    <small class="opacity-75">@student.Email</small>
                </div>
                <span class="badge bg-secondary font-monospace">ID: @student.StudentId</span>
            </div>

            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-4">
                        <h6 class="text-muted text-uppercase small mb-2">🎯 Điểm số (dùng kiểm tra tiên quyết)</h6>
                        @if (!student.Scores.Any())
                        {
                            <p class="text-muted small fst-italic">Chưa có điểm</p>
                        }
                        else
                        {
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Khóa học</th>
                                        <th class="text-center">Điểm</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var score in student.Scores)
                                    {
                                        <tr>
                                            <td>@score.CourseName</td>
                                            <td class="text-center fw-bold text-primary">@score.ScoreValue</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>

                    <div class="col-md-8">
                        <h6 class="text-muted text-uppercase small mb-2">📋 Lịch sử đăng ký</h6>
                        @if (!student.Registrations.Any())
                        {
                            <p class="text-muted small fst-italic">Chưa có đăng ký nào</p>
                        }
                        else
                        {
                            @foreach (var reg in student.Registrations)
                            {
                                string badgeClass = reg.Status switch
                                {
                                    RegistrationStatus.Paid      => "bg-success",
                                    RegistrationStatus.Pending   => "bg-warning text-dark",
                                    RegistrationStatus.Cancelled => "bg-danger",
                                    _                            => "bg-secondary"
                                };
                                string statusText = reg.Status switch
                                {
                                    RegistrationStatus.Paid      => "Đã thanh toán",
                                    RegistrationStatus.Pending   => "Chờ thanh toán",
                                    RegistrationStatus.Cancelled => "Đã hủy",
                                    _                            => "Không rõ"
                                };

                                <div class="border rounded p-3 mb-2">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <div>
                                            <strong>@reg.Class.Course.CourseName</strong>
                                            <span class="text-muted mx-1">—</span>
                                            <span>@reg.Class.ClassName</span>
                                        </div>
                                        <span class="badge @badgeClass">@statusText</span>
                                    </div>
                                    <div class="row g-2 small text-muted">
                                        <div class="col-auto">
                                            🗓 @reg.Class.Schedule.DayName
                                            @reg.Class.Schedule.StartTime.ToString(@"hh\:mm")–@reg.Class.Schedule.EndTime.ToString(@"hh\:mm")
                                        </div>
                                        <div class="col-auto">
                                            📅 Đăng ký: @reg.RegistrationDate.ToString("dd/MM/yyyy")
                                        </div>
                                    </div>

                                    @if (reg.Payments.Any())
                                    {
                                        @foreach (var pay in reg.Payments)
                                        {
                                            <div class="mt-2 pt-2 border-top small">
                                                <span class="text-muted">💳 @pay.PaymentMethod</span>
                                                <span class="mx-2">|</span>
                                                <span class="fw-bold text-success">@pay.Amount.ToString("N0") ₫</span>
                                                <span class="mx-2">|</span>
                                                <span class="font-monospace text-muted">@pay.TransactionReference</span>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="card-footer bg-light small">
                @if (student.StudentId == "S01")
                {
                    <span class="text-success">Test: Đăng ký IELTS Intermediate → Pass (điểm 5.0 ≥ 4.5)</span>
                }
                else if (student.StudentId == "S02")
                {
                    <span class="text-danger">Test: Đăng ký IELTS Intermediate → Fail điều kiện tiên quyết (điểm 3.5 &lt; 4.5)</span>
                }
                else if (student.StudentId == "S03")
                {
                    <span class="text-warning">Test: Đăng ký lớp Foundation A (Thứ 2) → Fail trùng lịch (đã có Business Thứ 2)</span>
                }
            </div>

        </div>
    }

    <div class="text-center mt-2">
        <a asp-page="/Courses/Index" class="btn btn-primary">→ Sang trang Đăng ký lớp</a>
    </div>
</div>
